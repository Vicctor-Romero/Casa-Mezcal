---
import { PHONE, PHONE_LABEL, ADDRESS, MAPS_URL, FACEBOOK_URL } from '../data/site';
import Button from './Button.astro';
---

<footer id="visit" class="bg-brown text-cream px-5 pt-8 pb-6 md:px-14 md:py-12">
  <h2 class="mb-3.5 text-[22px] text-cream md:text-[30px]" data-es="Visítanos">Visit us</h2>
  <div class="font-bold text-[15px] mb-1">Casa Mezcal — Family Mexican Restaurant</div>
  <div class="text-[13px] text-[#e3cfaf] mb-3">{ADDRESS}</div>

  <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 text-[13px] mb-4 [&_span:nth-child(odd)]:text-[#e3cfaf]">
    <span data-es="Lun–Sáb">Mon–Sat</span><span>11:00 AM – 9:00 PM</span>
    <span data-es="Domingo">Sunday</span><span>11:00 AM – 8:00 PM</span>
  </div>

  <div class="flex flex-wrap gap-2">
    <Button href={MAPS_URL} target="_blank" rel="noopener" data-es="Cómo llegar">Get directions</Button>
    <Button href={`tel:${PHONE}`} variant="ghost-light">{PHONE_LABEL}</Button>
    <Button href={FACEBOOK_URL} target="_blank" rel="noopener" variant="ghost-light">Facebook</Button>
  </div>

  <div class="text-center text-[11px] text-[#c9a87a] mt-6 border-t border-[#7e5535] pt-4">
    © 2026 Casa Mezcal · Alpine, Wyoming
  </div>
</footer>
