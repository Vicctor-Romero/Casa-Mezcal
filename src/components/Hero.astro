---
import { Image } from 'astro:assets';
import { PHONE } from '../data/site';
import Button from './Button.astro';
import comedor from '../assets/fotos/comedor.jpg';

// Papel picado: posiciones (x, y, rotación) sobre la curva del hilo
const flags = [
  [25, 8.3, 9.2], [75, 15.2, 6.5], [125, 19.7, 3.8], [175, 21.8, 1.1],
  [225, 21.6, -1.6], [275, 19.0, -4.3], [325, 14.0, -7.0], [365, 8.3, -9.2],
];
const flagColors = ['#D4622A', '#3E6B3F', '#E8A13C', '#3A5A8C'];
---

<section class="relative">
  <Image
    src={comedor}
    alt="Comedor de Casa Mezcal"
    widths={[640, 1000, 1600]}
    sizes="100vw"
    loading="eager"
    class="block w-full h-[340px] object-cover md:h-[480px]"
  />
  <div class="absolute inset-0 bg-linear-to-b from-[#2a180a]/15 to-[#2a180a]/[0.78]"></div>

  <svg class="absolute top-0 left-0 w-full h-auto md:max-h-[120px]" viewBox="0 0 390 64" preserveAspectRatio="xMidYMin meet" aria-hidden="true">
    <path d="M0,4 Q195,40 390,4" fill="none" stroke="#4A2E17" stroke-width="2"></path>
    {flags.map(([x, y, r], i) => (
      <g transform={`translate(${x},${y}) rotate(${r})`}>
        <polygon points="-15,0 15,0 15,16 0,26 -15,16" fill={flagColors[i % 4]} fill-opacity="0.78"></polygon>
        <circle cy="6.5" r="2.8" fill="#FBF4E6"></circle>
        <polygon points="-8,9 -5,12.5 -8,16 -11,12.5" fill="#FBF4E6"></polygon>
        <polygon points="8,9 11,12.5 8,16 5,12.5" fill="#FBF4E6"></polygon>
        <circle cy="14" r="1.7" fill="#FBF4E6"></circle>
        <circle cy="20.5" r="1.3" fill="#FBF4E6"></circle>
      </g>
    ))}
  </svg>

  <div class="absolute inset-x-0 bottom-0 px-5 py-[22px] md:px-14 md:py-10">
    <div class="font-body font-semibold text-[11px] tracking-[2px] uppercase text-[#f0b25e] mb-2" data-es="Recién abierto en Alpine, Wyoming">
      Now open in Alpine, Wyoming
    </div>
    <h1 class="mb-2 text-[30px] leading-[1.1] text-[#fbf4e6] md:text-5xl" data-es="Sabor mexicano auténtico, como en casa">
      Authentic Mexican flavor, made like home
    </h1>
    <p class="mb-4 text-sm leading-normal text-[#ebdcc3] max-w-[480px] md:text-base" data-es="Ingredientes frescos, recetas de familia y una bienvenida cálida. Ven a probar por qué todo Alpine habla de nosotros.">
      Fresh ingredients, family recipes, and a warm welcome. Come taste why Alpine can’t stop talking about us.
    </p>
    <div class="flex gap-2.5">
      <Button href="#menu" data-es="Ver menú">View menu</Button>
      <Button href={`tel:${PHONE}`} variant="ghost-light" data-es="Llámanos">Call us</Button>
    </div>
  </div>
</section>
