---
import { REVIEW_URL } from '../data/site';
import { reviews } from '../data/reviews';
import Button from './Button.astro';
---

<section class="mx-auto max-w-[1100px] px-5 py-[26px] md:px-14 md:py-12">
  <h2 class="mb-3.5 text-[22px] text-brown md:text-[30px]" data-es="Lo que dice la gente">What people say</h2>
  <div class="grid gap-2.5 md:grid-cols-3">
    {reviews.map((r) => (
      <div class="bg-cream-2 border border-border-warm rounded-[14px] p-4">
        <div class="text-amber text-sm tracking-[2px] mb-1.5" aria-label={`${r.rating} de 5 estrellas`}>
          {'★'.repeat(r.rating)}
        </div>
        <p class="mb-2 text-[13.5px] leading-normal" data-es={r.text.es}>{r.text.en}</p>
        <div class="font-bold text-xs text-tan">{r.name}</div>
      </div>
    ))}
  </div>
  <div class="flex flex-col items-center gap-2.5 mt-3.5 text-xs text-tan text-center md:flex-row md:justify-between">
    <span data-es="Reseñas de nuestro perfil de Google">Reviews from our Google profile</span>
    <Button href={REVIEW_URL} target="_blank" rel="noopener" variant="ghost" data-es="★ Déjanos una reseña en Google">
      ★ Leave us a review on Google
    </Button>
  </div>
</section>
