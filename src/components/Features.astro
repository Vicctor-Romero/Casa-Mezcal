---
const features = [
  { title: { en: 'Family recipes', es: 'Recetas de familia' }, desc: { en: 'Everything made in-house, made to order.', es: 'Todo hecho en casa, al momento.' } },
  { title: { en: 'Fresh seafood', es: 'Mariscos frescos' }, desc: { en: 'Camarones, ceviche & our seafood molcajete.', es: 'Camarones, ceviche y molcajete de mariscos.' } },
  { title: { en: 'Margaritas & mezcal', es: 'Margaritas y mezcal' }, desc: { en: 'Full bar: micheladas, mezcalitas & tequilas.', es: 'Bar completo: micheladas, mezcalitas y tequilas.' } },
];
---

<section id="why" class="mx-auto max-w-[1100px] px-5 py-[26px] md:px-14 md:py-12">
  <h2 class="mb-3.5 text-[22px] text-brown md:text-[30px]" data-es="Por qué Casa Mezcal">Why Casa Mezcal</h2>
  <div class="grid gap-2.5 md:grid-cols-3">
    {features.map((f) => (
      <div class="bg-cream-2 border border-border-warm rounded-2xl px-4 py-4">
        <div class="font-bold text-sm" data-es={f.title.es}>{f.title.en}</div>
        <div class="text-xs text-muted mt-1" data-es={f.desc.es}>{f.desc.en}</div>
      </div>
    ))}
  </div>
</section>
